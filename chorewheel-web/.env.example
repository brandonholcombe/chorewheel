# --- Google OAuth (Auth.js v5) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (local):  http://localhost:3000/api/auth/callback/google
# Authorized redirect URI (prod):   https://chorewheel.kodloki.io/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 32+ char random string used to sign Auth.js JWT sessions.
# Generate with: openssl rand -base64 32
APP_SESSION_SECRET=

# Public base URL of the app (used for OAuth callbacks / absolute links).
APP_DOMAIN=http://localhost:3000

# Where the SQLite file lives. Locally a relative path is fine; in the
# cluster this points at the mounted PVC, e.g. /data/chorewheel.sqlite
DATABASE_PATH=./data/chorewheel.sqlite
